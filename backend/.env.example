PORT=4000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret

# Leave DB_DIR unset for local (non-Docker) dev - it defaults to ./data.
# Docker Compose overrides this to /data (a mounted volume) automatically.
# DB_DIR=/data

# Comma-separated list of allowed frontend origins for CORS (e.g. your Netlify URL).
# Leave unset in local dev to allow all origins.
# FRONTEND_URL=https://sbxqgs.netlify.app

# Credentials for the one-time seeded super admin account (only used the
# very first time the database is created). Change the password after login.
SUPER_ADMIN_EMAIL=superadmin@safeboxenergy.com
SUPER_ADMIN_PASSWORD=SafeboxAdmin@2026

# Fixed brand identity (logo files are static assets, not user-editable).
# All other company profile content - name, address, mission, products, the
# page-2 photo, etc. - is stored in the database and editable from the
# Company Profile settings page in the app.
COMPANY_BRAND_COLOR=#B7DC38
COMPANY_BRAND_COLOR_LIGHT=#EEF7D9
CURRENCY_SYMBOL=₦
